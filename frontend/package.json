{
	"name": "aurora-frontend",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"typecheck": "tsc --noEmit",
		"preview": "vite preview",
		"stop": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Get-NetTCPConnection -LocalPort 7000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique | ForEach-Object { Stop-Process -Id $_ -Force -ErrorAction SilentlyContinue }\""
	},
	"dependencies": {
		"axios": "^1.6.0",
		"cesium": "^1.139.1",
		"framer-motion": "^12.36.0",
		"leaflet": "^1.9.4",
		"lucide-react": "^0.577.0",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-leaflet": "^4.2.1",
		"react-router-dom": "^6.30.3",
		"suncalc": "^1.9.0",
		"tailwind": "^3.1.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.2.0",
		"autoprefixer": "^10.4.27",
		"jsrepo": "^3.6.2",
		"postcss": "^8.5.8",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3",
		"vite": "^5.0.0",
		"vite-plugin-pwa": "^0.17.4"
	}
}
